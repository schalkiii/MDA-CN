{
    "task": [
        {
            "name": "DailyRewards",
            "label": "$task.DailyRewards.label",
            "entry": "DailyRewardsMain",
            "description": "$task.DailyRewards.description",
            "option": [
                "DailyRewardsFriendPoints",
                "DailyRewardsEmail",
                "DailyRewardsRankingRewards",
                "DailyRewardsMission",
                "DailyRewardsPassMain",
                "DailyRewardsDailyLogin",
                "DailyRewardsFreeRecruit"
            ],
            "group": [
