{
    "BattleStart": {
        "desc": "进入战斗",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "BattleMainVisible"
                ]
            }
        },
        "next": [
            "ManualInterceptionBattle",
            "[JumpBack]BattleCanQuickBattle",
            "[JumpBack]BattleCanBattle",
            "[JumpBack]BattleClosePage",
            "CommonEndTask"
        ]
    },
    "BattleCanQuickBattle": {
        "desc": "快速战斗可行性检测",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "QuickBattleVisible",
                    "QuickBattleAvailable"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500,
        "next": [
            "MultipleBattle",
            "MultipleBattleStart",
            "BattleOperationComplete"
        ]
    },
    "MultipleBattle": {
        "desc": "多次战斗",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    599,
                    463,
                    54,
                    22
                ],
                "expected": [
                    "剩余次数"
                ]
            }
        },
        "next": [
            "MultipleBattleClickMax",
            "MultipleBattleStart"
        ]
    },
    "MultipleBattleClickMax": {
        "desc": "多次战斗点击max",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    707,
                    491,
                    47,
                    30
                ],
                "template": [
                    "Common/MAX.png"
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "MultipleBattleClickMax",
            "MultipleBattleStart"
        ]
    },
    "MultipleBattleStart": {
        "desc": "多次战斗点击进行战斗",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    705,
                    536,
                    88,
                    37
                ],
                "expected": [
                    "进行战斗"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "BattleInBattle"
        ]
    },
    "BattleInBattle": {
        "desc": "战斗中",
        "timeout": 180000,
        "next": [
            "[JumpBack]BattleClickAutoBurst",
            "[JumpBack]BattleClickAutoShoot",
            "[JumpBack]DialoguesSkipStory",
            "[JumpBack]BattleNextState",
            "BattleOperationComplete",
            "BattleOperationFailed"
        ]
    },
    "BattleClickAutoBurst": {
        "desc": "点击自动爆裂",
        "max_hit": 1,
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    100,
                    40
                ],
                "template": [
                    "Battle/AutoBurst.png"
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "BattleClickAutoShoot": {
        "desc": "点击自动射击",
        "max_hit": 1,
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    100,
                    40
                ],
                "template": [
                    "Battle/AutoShoot.png"
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "BattleNextState": {
        "desc": "下一关卡",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "BattleNextStateVisible",
                    "BattleNextStateAvailable"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 3000
    },
    "BattleNextStateVisible": {
        "desc": "下一关卡可见",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1140,
                    659,
                    122,
                    37
                ],
                "expected": [
                    ".*关卡.*"
                ]
            }
        }
    },
    "BattleNextStateAvailable": {
        "desc": "下一关卡可点击",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "BattleNextStateVisible",
                "lower": [
                    200,
                    200,
                    200
                ],
                "upper": [
                    255,
                    255,
                    255
                ],
                "count": 100
            }
        }
    },
    "BattleOperationComplete": {
        "desc": "战斗胜利结算",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "BattleEscVisible"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "BattleOperationComplete",
            "CommonEndTask"
        ]
    },
    "BattleOperationFailed": {
        "desc": "战斗失败结算",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "BattleFailedVisible"
                ]
            }
        },
        "next": [
            "CommonGoBack",
            "BattleOperationFailed"
        ]
    },
    "BattleEscVisible": {
        "desc": "Esc可见",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    567,
                    610,
                    160,
                    90
                ],
                "expected": [
                    "ESC"
                ]
            }
        }
    },
    "BattleFailedVisible": {
        "desc": "战败可见",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    616,
                    262,
                    48,
                    30
                ],
                "expected": [
                    "战败"
                ]
            }
        }
    },
    "BattleCanBattle": {
        "desc": "战斗可行性检测",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "BattleMainVisible",
                    "BattleAvailable"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "BattleInBattle"
        ]
    },
    "BattleClosePage": {
        "desc": "退出战斗",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    815,
                    358,
                    35,
                    31
                ],
                "template": [
                    "Battle/BattleCloseButton.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "QuickBattleVisible": {
        "desc": "快速战斗的标识",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    671,
                    571,
                    157,
                    114
                ],
                "expected": [
                    ".*快速战斗.*"
                ]
            }
        }
    },
    "QuickBattleAvailable": {
        "desc": "可以快速战斗的标识",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "QuickBattleVisible",
                "lower": [
                    200,
                    200,
                    200
                ],
                "upper": [
                    255,
                    255,
                    255
                ],
                "count": 100
            }
        }
    },
    "BattleMainVisible": {
        "desc": "战斗的标识",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    671,
                    571,
                    157,
                    114
                ],
                "expected": [
                    "进入战斗"
                ]
            }
        }
    },
    "BattleAvailable": {
        "desc": "可以战斗的标识",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "BattleMainVisible",
                "lower": [
                    200,
                    200,
                    200
                ],
                "upper": [
                    255,
                    255,
                    255
                ],
                "count": 200
            }
        }
    }
}
