        "next": [
            "[JumpBack]DailyRewardsPassChangeClick",
            "DailyRewardsPassFlow",
            "CommonEndTask"
        ]
    },
    "DailyRewardsPassChangeClick": {
        "desc": "点击更换pass", //确保其一定时间内不会再次更换，防止出现在更换途中识别导致失败的情况
