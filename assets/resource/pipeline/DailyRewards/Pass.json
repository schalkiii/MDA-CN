        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1116,
                    91,
                    163,
                    66
                ],
                "template": [
                    "DailyRewards/Pass/PassChange.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500
    },
    "DailyRewardsPassFlow": {
        "desc": "Pass入口",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1116,
                    91,
                    163,
                    66
                ],
                "template": [
                    "Common/RedDot.png",
                    "Common/PassRedDot.png"
