    "DailyRewardsClaimRewardFlow": {
        "desc": "领取Pass奖励流程",
        "next": [
            "[JumpBack]DailyRewardsPassClaimAll",
            "CommonConfirmReward",
            "CommonEndTask"
        ]
    },
    "DailyRewardsPassClaimed": {
        "desc": "已领取",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    553,
                    655,
                    175,
                    30
                ],
                "lower": [
                    100,
                    100,
                    100
                ],
                "upper": [
                    180,
                    180,
                    180
                ],
                "count": 500
            }
        }
    },
    "DailyRewardsPassClaimAll": {
        "desc": "领取所有Pass奖励",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "DailyRewardsPassClaimAllButtonVisible",
                    "DailyRewardsPassAvailable"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500
    },
    "DailyRewardsPassClaimAllButtonVisible": {
        "desc": "Pass文本可见",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    553,
                    655,
                    175,
                    30
                ],
                "expected": [
                    ".*全部.*"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500
    },
    "DailyRewardsPassAvailable": {
        "desc": "Pass可用",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "DailyRewardsPassClaimAllButtonVisible",
                "lower": [
                    200,
                    200,
                    200
                ],
                "upper": [
                    255,
                    255,
                    255
                ],
                "count": 100
            }
        }
    }
