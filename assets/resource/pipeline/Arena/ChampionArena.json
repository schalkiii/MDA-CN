{
    "ArenaEnterChampionArena": {
        "max_hit": 5,
        "desc": "进入冠军竞技场",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "ChampionArena",
                    "ChampionArenaRedDotVisible"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "ChampionArenaCornerFlow"
        ]
    },
    "ChampionArenaMainPageEntered": {
        "desc": "处于冠军竞技场",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    15,
                    70,
                    25
                ],
                "expected": [
                    "冠军竞技场"
                ]
            }
        },
        "post_wait_freezes": 500
    },
    "ChampionArenaCornerFlow": {
        "desc": "冠军竞技场流程",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "ChampionArenaMainPageEntered"
                ]
            }
        },
        "next": [
            "ChampionArenaEnterChampionsDuel",
            "ArenaCornerFlow",
            "[JumpBack]CommonGoBack"
        ]
    },
    "ChampionArenaEnterChampionsDuel": {
        "desc": "进入冠军对决",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    477,
                    523,
                    332,
                    39
                ],
                "expected": [
                    ".*剩余.*",
                    ".*分钟.*"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]ArenaClickCheerReward",
            "ChampionArenaCompetitionFlow"
        ]
    },
    "ArenaClickCheerReward": {
        "desc": "应援奖励",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    596,
                    559,
                    95,
                    30
                ],
                "expected": [
                    "点击进行下一步"
                ]
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "ChampionArenaCompetitionEntered": {
        "desc": "处于比赛页面",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    15,
                    70,
                    25
                ],
                "expected": [
                    "小组循环赛",
                    "晋级赛",
                    "冠军争霸赛"
                ]
            }
        }
    },
    "ChampionArenaCompetitionFlow": {
        "desc": "比赛流程",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "ChampionArenaCompetitionEntered"
                ]
            }
        },
        "next": [
            "ArenaClickCheerUp",
            "[JumpBack]ArenaCheerResult"
        ]
    },
    "ArenaCheerResult": {
        "desc": "应援结果确认",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    603,
                    240,
                    73,
                    21
                ],
                "expected": [
                    ".*应援.*"
                ]
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "ArenaClickCheerUp": {
        "desc": "应援",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    571,
                    630,
                    141,
                    32
                ],
                "expected": [
                    "应援"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500,
        "next": [
            "ChampionArenaCheerUpAvailableFlow",
            "ChampionArenaClickCheerUpRight",
            "ChampionArenaCloseCheerUpPage"
        ]
    },
    "ChampionArenaCloseCheerUpPage": {
        "desc": "关闭应援页面", //通常情况下是因为错过了上次应援
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    587,
                    530,
                    108,
                    38
                ],
                "expected": [
                    ".*关闭.*"
                ]
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "ChampionArenaCheerUpAvailable": {
        "desc": "应援可用",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    487,
                    322,
                    51,
                    19
                ],
                "expected": [
                    "^[5-9]"
                ]
            }
        }
    },
    "ChampionArenaCheerUpAvailableFlow": {
        "desc": "应援可用流程",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "ChampionArenaCheerUpAvailable"
                ]
            }
        },
        "next": [
            "ArenaClickCheerUpLeft"
        ]
    },
    "ArenaClickCheerUpLeft": {
        "desc": "应援左边",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    540,
                    352,
                    62,
                    25
                ],
                "expected": [
                    "选择"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CommonConfirmAction"
        ]
    },
    "ChampionArenaClickCheerUpRight": {
        "desc": "应援右边",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    708,
                    351,
                    63,
                    26
                ],
                "expected": [
                    "选择"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CommonConfirmAction"
        ]
    },
    "ChampionArenaRedDotVisible": {
        "desc": "冠军竞技场的红点",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    799,
                    448,
                    26,
                    23
                ],
                "template": [
                    "Common/RedDot.png"
                ]
            }
        }
    },
    "ChampionArena": {
        "desc": "冠军竞技场",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    490,
                    507,
                    95,
                    31
                ],
                "expected": [
                    "CHAMPION"
                ]
            }
        }
    }
}
