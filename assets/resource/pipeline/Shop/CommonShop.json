{
    "CommonShop": {
        "desc": "普通商店",
        "max_hit": 1,
        "next": [
            "[JumpBack]ShopEnterCommonShop",
            "[JumpBack]ShopConfirmPurchase",
            "[JumpBack]FreeGoodsPurchase",
            "[JumpBack]CoreDustCasePurchase",
            "[JumpBack]FreeReset",
            "BaseEndTask"
        ]
    },
    "ShopEnterCommonShop": {
        "desc": "进入普通商店",
        "max_hit": 1,
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    255,
                    55,
                    390
                ],
                "template": [
                    "Shop/CommonShopSelected.png",
                    "Shop/CommonShopNotSelected.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "ShopCommonShopEntered",
            "ShopEnterCommonShop"
        ]
    },
    "ShopCommonShopEntered": {
        "desc": "处于普通商店",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    68,
                    264,
                    119,
                    20
                ],
                "expected": [
                    "普通商店"
                ]
            }
        }
    },
    "FreeGoodsPurchase": {
        "desc": "购买免费商品",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    159,
                    351,
                    26,
                    26
                ],
                "template": [
                    "Common/RedDot.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "CoreDustCasePurchase": {
        "desc": "购买芯尘盒",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    182,
                    352,
                    109,
                    164
                ],
                "template": [
                    "Shop/CoreDustCase.png"
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "FreeReset": {
        "desc": "免费刷新",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    217,
                    304,
                    56,
                    27
                ],
                "template": [
                    "Shop/FreeReset.png"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    -50,
                    20,
                    0,
                    0
                ]
            }
        },
        "next": [
            "ShopConfirmReset",
            "FreeReset"
        ]
    },
    "ShopConfirmReset": {
        "desc": "确认刷新",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    594,
                    429,
                    220,
                    250
                ],
                "template": [
                    "Common/ConfirmWithCircle.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 1000
    },
    "ShopPurchaseBlockedByGemVisible": {
        "desc": "当货品为芯尘盒且货币为宝珠时不购买转而关闭页面",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "ShopGemVisible",
                    "ShopGoodsVisible"
                ]
            }
        }
    },
    "ShopPurchaseBlockedByGemFlow": {
        "desc": "当货品为芯尘盒且货币为宝珠时不购买转而关闭页面",
        "next": [
            "ShopPurchaseBlockedByGemVisible",
            "[JumpBack]CommonClosePage",
            "FreeReset",
            "BaseEndTask"
        ]
    },
    "ShopGemVisible": {
        "desc": "宝珠检查",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    585,
                    516,
                    113,
                    34
                ],
                "template": [
                    "Shop/GemCheck.png"
                ]
            }
        }
    },
    "ShopGoodsVisible": {
        "desc": "商品检查",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    610,
                    166,
                    60,
                    30
                ],
                "expected": "芯尘盒"
            }
        }
    }
}
