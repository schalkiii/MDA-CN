{
    "SimulationRoomStartOverclock": {
        "desc": "点击开始超频",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    572,
                    523,
                    116,
                    115
                ],
                "template": [
                    "SimulationRoom/Rewards0.png"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    0,
                    -25,
                    0,
                    0
                ]
            }
        },
        "next": [
            "[JumpBack]SimulationRoomOpenBiosSetting",
            "SimulationRoomBeginOverclockSimulation",
            "SimulationRoomStartOverclock"
        ]
    },
    "SimulationRoomOpenBiosSetting": {
        "desc": "点击BIOS设置",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    597,
                    422,
                    105,
                    32
                ],
                "expected": [
                    "BIOS SETTING"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500,
        "next": [
            "SimulationRoomBiosSettingFlow"
        ]
    },
    "SimulationRoomBiosSettingFlow": {
        "desc": "BIOS设置",
        "next": [
            "SimulationRoomSelectOverclockLevel25",
            "[JumpBack]SimulationRoomSelectOverclockOption",
            "[JumpBack]SimulationRoomScrollOverclockOptionsUp"
        ]
    },
    "SimulationRoomSelectOverclockLevel25": {
        "desc": "检查难度是否为25",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    496,
                    191,
                    33,
                    19
                ],
                "expected": [
                    "25"
                ]
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "SimulationRoomSelectOverclockOption": {
        "desc": "选择超频选项",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    478,
                    255,
                    325,
                    219
                ],
                "template": [
                    "SimulationRoom/EnemyWeaponUpⅢ.png",
                    "SimulationRoom/EnemyArmorUpⅢ.png",
                    "SimulationRoom/EnemyVitalsUpⅢ.png",
                    "SimulationRoom/NoRecycling.png",
                    "SimulationRoom/AggressiveTactics.png",
                    "SimulationRoom/RushHourⅢ.png",
                    "SimulationRoom/RelevantPersonnelOnly.png"
                ],
                "threshold": 0.9,
                "index": -1
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500
    },
    "SimulationRoomScrollOverclockOptionsUp": {
        "desc": "模拟室超频向上滑动",
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    480,
                    360
                ],
                "end": [
                    480,
                    260
                ],
                "end_hold": 300
            }
        },
        "post_wait_freezes": 20
    },
